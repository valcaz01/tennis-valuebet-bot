# ── Copier ce fichier en .env et remplir les valeurs ──

# Token du bot Telegram (obtenu via @BotFather)
TELEGRAM_BOT_TOKEN=ton_token_ici

# The Odds API — https://the-odds-api.com (plan gratuit : 500 req/mois)
ODDS_API_KEY=ton_odds_api_key_ici

# API-Sports Tennis — https://rapidapi.com/api-sports/api/api-tennis
# Plan gratuit : 100 req/jour
APISPORTS_KEY=ton_apisports_key_ici

# Paramètres value bet
MIN_EDGE=0.05           # Edge minimum pour déclencher une alerte (5%)
KELLY_FRACTION=0.25     # Fraction Kelly (25% = quart de Kelly)
BANKROLL=1000           # Bankroll de référence en €

# Scheduler
SCAN_INTERVAL=30        # Minutes entre deux scans automatiques
